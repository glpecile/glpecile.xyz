---
import PageIntro from "@/components/page-intro.astro";
import SectionLabel from "@/components/section-label.astro";
import SiteLayout from "@/layouts/site-layout.astro";
import WorkTimeline from "@/components/work-timeline.astro";
import { cvDownloadName } from "@/lib/cv";
import { parseInlineLinks } from "@/lib/inline-links";

import { siteConfig } from "#config/site";
import type {
	CertificateItem,
	ContactInfo,
	CvFile,
	EducationItem,
	LanguageItem,
	ProjectEntry,
	SkillGroup,
	WorkExperience,
} from "#config/site";

const work: readonly WorkExperience[] = siteConfig.work;
const projects: readonly ProjectEntry[] = siteConfig.projects;
const skills: readonly SkillGroup[] = siteConfig.skills;
const education: readonly EducationItem[] = siteConfig.education;
const languages: readonly LanguageItem[] = siteConfig.languages;
const certificates: readonly CertificateItem[] = siteConfig.certificates;
const cv: CvFile = siteConfig.cv;
const contact: ContactInfo = siteConfig.contact;
const cvFileName = cvDownloadName();
---

<SiteLayout
	title="Work"
	description="Work history, projects, skills, education, languages, certificates, and a downloadable CV."
	path="/work"
	previewPath="/work/preview"
>
	<section class="space-y-6">
		<PageIntro
			label="work"
			title="Past work experience."
			description="+ projects, skills, education & certificates."
		/>

		<div class="space-y-2" data-reveal>
			<p class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm sm:text-base">
				<a
					class="terminal-link inline-flex items-center gap-2"
					href={cv.href}
					download={cvFileName}
				>
					[{cv.label}]
				</a>
				<a class="terminal-link" href="/work/index.html.md">[markdown]</a>
			</p>
			<p class="text-tone-faint text-sm">{contact.email} · {contact.location}</p>
		</div>
	</section>

	<section class="space-y-4" data-reveal>
		<SectionLabel label="roles" />

		{work.length === 0 ? (
			<p class="text-tone-soft text-sm">no work yet.</p>
		) : (
			<WorkTimeline work={work} detail="highlights" />
		)}
	</section>

	<section class="space-y-4" data-reveal>
		<SectionLabel label="projects" />

		{projects.length === 0 ? (
			<p class="text-tone-soft text-sm">no projects yet.</p>
		) : (
			<ol class="space-y-5">
				{projects.map((project) => (
					<li class="space-y-1">
						<p class="text-base leading-8 sm:text-lg">
							{project.url ? (
								<a
									class="terminal-link"
									href={project.url}
									target="_blank"
									rel="noopener noreferrer"
								>
									{project.name}
								</a>
							) : (
								<span class="text-foreground">{project.name}</span>
							)}
							<span class="text-tone-faint"> · </span>
							<span class="text-tone-soft">{project.stack}</span>
						</p>
						{project.period && (
							<p class="text-tone-soft text-sm leading-7 sm:text-base">
								{project.period}
							</p>
						)}
						<ul class="space-y-1 pt-1">
							{project.highlights.map((highlight) => (
								<li class="text-tone-mid max-w-3xl text-sm leading-7 sm:text-base">
									<span class="text-tone-faint">- </span>
									{parseInlineLinks(highlight).map((segment) =>
										segment.url ? (
											<a class="terminal-link" href={segment.url}>
												{segment.text}
											</a>
										) : (
											segment.text
										),
									)}
								</li>
							))}
						</ul>
					</li>
				))}
			</ol>
		)}
	</section>

	<section class="space-y-4" data-reveal>
		<SectionLabel label="skills" />

		<ul class="grid gap-x-10 gap-y-2 sm:grid-cols-2">
			{skills.map((group) => (
				<li class="grid gap-1 sm:grid-cols-[8rem_minmax(0,1fr)] sm:items-baseline sm:gap-x-4">
					<p class="text-foreground text-sm sm:text-base">{group.category}</p>
					<p class="text-tone-soft text-sm leading-7 sm:text-base">
						{group.items.join(", ")}
					</p>
				</li>
			))}
		</ul>
	</section>

	<section class="space-y-4" data-reveal>
		<SectionLabel label="education" />

		{education.length === 0 ? (
			<p class="text-tone-soft text-sm">no education yet.</p>
		) : (
			<ol class="space-y-5">
				{education.map((item) => (
					<li class="space-y-1">
						<p class="text-base leading-8 sm:text-lg">
							{item.url ? (
								<a
									class="terminal-link"
									href={item.url}
									target="_blank"
									rel="noopener noreferrer"
								>
									{item.school}
								</a>
							) : (
								<span class="text-foreground">{item.school}</span>
							)}
						</p>
						<p class="text-tone-soft text-sm leading-7 sm:text-base">
							{item.credential}
						</p>
						<p class="text-tone-soft text-sm leading-7 sm:text-base">
							{item.period}
						</p>
						{item.details?.map((detail) => (
							<p class="text-tone-mid max-w-3xl text-sm leading-8 sm:text-base">
								{detail}
							</p>
						))}
					</li>
				))}
			</ol>
		)}
	</section>

	<section class="space-y-4" data-reveal>
		<SectionLabel label="languages" />

		<ul class="grid gap-x-10 gap-y-2 sm:grid-cols-2">
			{languages.map((item) => (
				<li class="grid gap-1 sm:grid-cols-[8rem_minmax(0,1fr)] sm:items-baseline sm:gap-x-4">
					<p class="text-foreground text-sm sm:text-base">{item.language}</p>
					<p class="text-tone-soft text-sm leading-7 sm:text-base">{item.level}</p>
				</li>
			))}
		</ul>
	</section>

	<section class="space-y-4" data-reveal>
		<SectionLabel label="certificates" />

		{certificates.length === 0 ? (
			<p class="text-tone-soft text-sm">no certificates yet.</p>
		) : (
			<ol class="space-y-5">
				{certificates.map((certificate) => (
					<li class="space-y-1">
						<p class="text-base leading-8 sm:text-lg">
							{certificate.url ? (
								<a
									class="terminal-link"
									href={certificate.url}
									target="_blank"
									rel="noopener noreferrer"
								>
									{certificate.title}
								</a>
							) : (
								<span class="text-foreground">{certificate.title}</span>
							)}
						</p>
						<p class="text-tone-soft text-sm leading-7 sm:text-base">
							{certificate.issuer}
						</p>
						<p class="text-tone-soft text-sm leading-7 sm:text-base">
							Issued {certificate.issued}
						</p>
						{certificate.details?.map((detail) => (
							<p class="text-tone-mid max-w-3xl text-sm leading-8 sm:text-base">
								{detail}
							</p>
						))}
					</li>
				))}
			</ol>
		)}
	</section>
</SiteLayout>
