---
import ErrorPage from "@/components/error-page.astro";

import { siteConfig } from "#config/site";

const navHint = siteConfig.shortcuts.nav
	.map((item) => `[${item.shortcut}] for ${item.title.toLowerCase()}`)
	.join(", ");
---

<ErrorPage
	code="404"
	title="Page not found."
	description="That path does not exist here, or it moved somewhere else."
	hint={`Use ${navHint}.`}
	path="/404"
/>
