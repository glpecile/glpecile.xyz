---
import MoreLink from "@/components/more-link.astro";
import PageIntro from "@/components/page-intro.astro";
import SectionLabel from "@/components/section-label.astro";
import SiteLayout from "@/layouts/site-layout.astro";
import { formatDate, getBlogPostUrl, getBlogPosts } from "@/lib/blog";

import { siteConfig } from "../../config/site";

const socialLinks = Object.entries(siteConfig.links);
const posts = await getBlogPosts();
const work = siteConfig.work;
const featuredWork = work.slice(0, 3);
const hasMoreWork = work.length > featuredWork.length;
---

<SiteLayout>
	<PageIntro
		label="home"
		title="Frontend Engineer."
		description="Shipping websites and apps from time to time."
		extra={'shortcut keys: <span class="text-tone-mid">[h] home</span><span class="text-tone-faint"> / </span><span class="text-tone-mid">[b] blog</span><span class="text-tone-faint"> / </span><span class="text-tone-mid">[w] work</span>'}
	/>

	<section class="space-y-4">
		<SectionLabel label="blog" />

		{posts.length === 0 ? (
			<p class="text-tone-soft text-sm">no posts yet.</p>
		) : (
			<ol class="space-y-4">
				{posts.map((post) => (
					<li class="grid gap-1 sm:grid-cols-[8.5rem_minmax(0,1fr)] sm:items-baseline sm:gap-x-5">
						<p class="text-tone-faint text-sm leading-7 sm:text-base">
							{formatDate(post.data.updatedDate ?? post.data.pubDate).toLowerCase()}
						</p>
						<p class="text-base leading-8 sm:text-lg">
							<a class="terminal-link" href={getBlogPostUrl(post.id)}>
								{post.data.title}
							</a>
						</p>
					</li>
				))}
			</ol>
		)}

		{posts.length > 0 && <MoreLink href="/blog" />}
	</section>

	<section class="space-y-4">
		<SectionLabel label="work" />
		<ol class="space-y-5">
			{featuredWork.map((job) => (
				<li class="space-y-1">
					<p class="text-base leading-8 sm:text-lg">
						<span class="text-foreground">{job.role}</span>
						<span class="text-tone-faint"> @ </span>
						{job.url ? (
							<a
								class="terminal-link"
								href={job.url}
								target="_blank"
								rel="noopener noreferrer"
							>
								{job.company}
							</a>
						) : (
							<span class="text-tone-strong">{job.company}</span>
						)}
					</p>
					<p class="text-tone-soft text-sm leading-7 sm:text-base">
						{job.period}
					</p>
					<p class="text-tone-soft text-sm leading-7 sm:text-base">
						{job.place}
					</p>
					{job.summary && (
						<p class="text-tone-mid max-w-3xl text-sm leading-8 sm:text-base">
							{job.summary}
						</p>
					)}
				</li>
			))}
		</ol>
		{hasMoreWork && <MoreLink href="/work" />}
	</section>

	<section class="space-y-3">
		<SectionLabel label="socials" />
		<ul class="space-y-2 text-sm sm:text-base">
			{socialLinks.map(([label, href]) => (
				<li>
					<a
						href={href}
						target="_blank"
						rel="noopener noreferrer"
					class="terminal-link inline-flex items-center gap-3"
				>
						<span class="text-tone-faint">-</span>
						<span class="capitalize">{label}</span>
					</a>
				</li>
			))}
		</ul>
	</section>
</SiteLayout>
