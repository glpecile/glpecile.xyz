---
import SiteLayout from "@/layouts/SiteLayout.astro";
import { formatDate, getBlogPostUrl, getBlogPosts } from "@/lib/blog";

import { siteConfig } from "../../config/site";

const socialLinks = Object.entries(siteConfig.links);
const work = siteConfig.work;
const latestPost = (await getBlogPosts())[0];
---

<SiteLayout>
	<section class="space-y-4">
		<p class="eyebrow">* home</p>
		<h1 class="max-w-3xl text-3xl font-bold tracking-tight sm:text-4xl">
			Frontend Engineer.
		</h1>
		<p class="max-w-3xl text-sm leading-8 text-foreground/68 sm:text-base">
			Shipping websites and apps from time to time.
		</p>
		<p class="text-sm text-foreground/50">
			shortcut keys: <span class="text-foreground/72">[h] home</span>
			<span class="text-foreground/35"> / </span>
			<span class="text-foreground/72">[b] blog</span>
		</p>
	</section>

	{latestPost && (
		<section class="space-y-3">
			<p class="eyebrow">* latest</p>
			<p class="text-base leading-8 sm:text-lg">
				<a class="terminal-link" href={getBlogPostUrl(latestPost.id)}>
					{latestPost.data.title}
				</a>
				<span class="text-foreground/40">
					 {"//"} {formatDate(latestPost.data.updatedDate ?? latestPost.data.pubDate)}
				</span>
			</p>
			<p class="max-w-3xl text-sm leading-8 text-foreground/62 sm:text-base">
				{latestPost.data.description}
			</p>
		</section>
	)}

	<section class="space-y-4">
		<p class="eyebrow">* work</p>
		<ol class="space-y-5">
			{work.map((job) => (
				<li class="space-y-1">
					<p class="text-base leading-8 sm:text-lg">
						<span class="text-foreground">{job.role}</span>
						<span class="text-foreground/38"> @ </span>
						{job.url ? (
							<a
								class="terminal-link text-foreground/72"
								href={job.url}
								target="_blank"
								rel="noopener noreferrer"
							>
								{job.company}
							</a>
						) : (
							<span class="text-foreground/72">{job.company}</span>
						)}
					</p>
					<p class="text-sm leading-7 text-foreground/50 sm:text-base">
						{job.period}
					</p>
					<p class="text-sm leading-7 text-foreground/50 sm:text-base">
						{job.place}
					</p>
					{job.summary && (
						<p class="max-w-3xl text-sm leading-8 text-foreground/62 sm:text-base">
							{job.summary}
						</p>
					)}
				</li>
			))}
		</ol>
	</section>

	<section class="space-y-3">
		<p class="eyebrow">* socials</p>
		<ul class="space-y-2 text-sm sm:text-base">
			{socialLinks.map(([label, href]) => (
				<li>
					<a
						href={href}
						target="_blank"
						rel="noopener noreferrer"
						class="terminal-link inline-flex items-center gap-3"
					>
						<span class="text-foreground/35">-</span>
						<span class="capitalize">{label}</span>
					</a>
				</li>
			))}
		</ul>
	</section>
</SiteLayout>
