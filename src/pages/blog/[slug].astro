---
import type { GetStaticPaths } from "astro";
import { render, type CollectionEntry } from "astro:content";

import SectionLabel from "@/components/section-label.astro";
import SiteLayout from "@/layouts/site-layout.astro";
import { formatDate, getBlogPosts } from "@/lib/blog";

export const getStaticPaths = (async () => {
	const posts = await getBlogPosts();

	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}) satisfies GetStaticPaths;

type Props = {
	post: CollectionEntry<"blog">;
};

const { post } = Astro.props as Props;
const { Content } = await render(post);
const displayDate = post.data.updatedDate ?? post.data.pubDate;
const postPath = `/blog/${post.id}`;
---

<SiteLayout
	title={post.data.title}
	description={post.data.description}
	path={postPath}
	previewPath={`${postPath}/preview`}
	type="article"
	publishedTime={post.data.pubDate.toISOString()}
>
	<article class="space-y-6">
		<a
			href="/blog"
			class="terminal-link inline-flex items-center gap-2 text-sm"
		>
			<svg viewBox="0 0 16 16" aria-hidden="true" class="h-4 w-4 fill-current">
				<path d="M7.3 3.22a.75.75 0 0 1 1.06 1.06L5.65 7h7.6a.75.75 0 0 1 0 1.5h-7.6l2.71 2.72a.75.75 0 1 1-1.06 1.06L3.31 8.28a.75.75 0 0 1 0-1.06L7.3 3.22Z"></path>
			</svg>
			<span>Back to blog</span>
		</a>

		<header class="space-y-4">
			<SectionLabel label="post" />
			<p class="text-tone-soft text-sm">{formatDate(displayDate)}</p>
			<h1 class="page-heading max-w-3xl text-3xl font-bold tracking-tight sm:text-5xl">
				{post.data.title}
			</h1>
			<p class="text-tone-mid max-w-3xl text-sm leading-8 sm:text-base">
				{post.data.description}
			</p>
		</header>

		<div class="blog-prose">
			<Content />
		</div>

		<script is:inline>
			const codeBlocks = document.querySelectorAll(".blog-prose pre.astro-code");
			const copyLabels = {
				idle: "[copy]",
				success: "[copied]",
				error: "[unavailable]",
			};

			const formatLanguage = (value) => {
				if (typeof value !== "string" || value.length === 0 || value === "plaintext") {
					return "text";
				}

				return value.toLowerCase();
			};

			const getCodeText = (pre) => {
				const code = pre.querySelector("code");

				if (!(code instanceof HTMLElement)) {
					return "";
				}

				const lines = Array.from(code.querySelectorAll(".line"));

				if (lines.length === 0) {
					return code.textContent ?? "";
				}

				return lines.map((line) => line.textContent ?? "").join("\n");
			};

			const copyText = async (text) => {
				if (navigator.clipboard?.writeText) {
					await navigator.clipboard.writeText(text);
					return;
				}

				if (
					typeof ClipboardItem !== "undefined" &&
					navigator.clipboard?.write
				) {
					const blob = new Blob([text], { type: "text/plain" });
					await navigator.clipboard.write([
						new ClipboardItem({
							"text/plain": blob,
						}),
					]);
					return;
				}

				throw new Error("copy unavailable");
			};

			codeBlocks.forEach((pre) => {
				if (!(pre instanceof HTMLElement) || pre.parentElement?.classList.contains("code-frame")) {
					return;
				}

				const wrapper = document.createElement("div");
				wrapper.className = "code-frame";
				pre.parentNode?.insertBefore(wrapper, pre);

				const toolbar = document.createElement("div");
				toolbar.className = "code-toolbar";

				const language = document.createElement("span");
				language.className = "code-language";
				language.textContent = formatLanguage(pre.dataset.language);

				toolbar.append(language);

				const button = document.createElement("button");
				button.type = "button";
				button.className = "code-copy-button";
				button.setAttribute("aria-label", "Copy code to clipboard");
				button.textContent = copyLabels.idle;

				let resetTimer = 0;

				button.addEventListener("click", async () => {
					window.clearTimeout(resetTimer);

					try {
						await copyText(getCodeText(pre));
						button.textContent = copyLabels.success;
					} catch {
						button.textContent = copyLabels.error;
					}

					resetTimer = window.setTimeout(() => {
						button.textContent = copyLabels.idle;
					}, 1600);
				});

				toolbar.append(button);
				wrapper.append(toolbar, pre);
			});
		</script>
	</article>
</SiteLayout>
