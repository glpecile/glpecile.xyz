---
import PageIntro from "@/components/page-intro.astro";
import SiteLayout from "@/layouts/site-layout.astro";
import { formatDate, getBlogPostUrl, getBlogPosts } from "@/lib/blog";

const posts = await getBlogPosts();
---

<SiteLayout
	title="Blog"
	description="Thoughts, experiments, and tiny posts."
	path="/blog"
	previewPath="/blog/preview"
>
	<section class="space-y-4">
		<PageIntro
			label="blog"
			title="Small notes. Full-sized blog."
			description="Thoughts, experiments, and tiny posts that still deserve a permanent URL."
		/>

		{posts.length === 0 ? (
			<p class="text-tone-soft text-sm">no posts yet.</p>
		) : (
			<ol class="space-y-5">
				{posts.map((post, index) => (
					<li class="space-y-1">
						<p class="text-tone-faint text-xs uppercase tracking-[0.28em]">
							{formatDate(post.data.updatedDate ?? post.data.pubDate)}
						</p>
						<p class="text-base leading-8 sm:text-lg">
							<a class="terminal-link" href={getBlogPostUrl(post.id)}>
								{post.data.title}
							</a>
							{index < 9 && (
								<span class="text-tone-faint"> [{index + 1}]</span>
							)}
						</p>
						<p class="text-tone-mid max-w-3xl text-sm leading-8 sm:text-base">
							{post.data.description}
						</p>
					</li>
				))}
			</ol>
		)}

		{posts.length > 0 && (
			<div class="text-tone-soft space-y-1 text-sm">
				<p>use <span class="text-tone-mid">[1-9]</span> for the latest posts.</p>
				<p>
					or subscribe via the <a class="terminal-link" href="/blog/rss.xml">rss feed</a>.
				</p>
			</div>
		)}
	</section>

	<script
		is:inline
		define:vars={{ recentPostUrls: posts.slice(0, 9).map((post) => getBlogPostUrl(post.id)) }}
	>
		(() => {
			const editableTags = new Set(["INPUT", "TEXTAREA", "SELECT"]);

			const onBlogShortcut = (event) => {
				if (
					event.defaultPrevented ||
					event.repeat ||
					event.metaKey ||
					event.ctrlKey ||
					event.altKey
				) {
					return;
				}

				const target = event.target;

				if (
					target instanceof HTMLElement &&
					(editableTags.has(target.tagName) || target.isContentEditable)
				) {
					return;
				}

				if (!/^\d$/.test(event.key)) {
					return;
				}

				const index = Number(event.key) - 1;
				const href = recentPostUrls[index];

				if (!href) {
					return;
				}

				event.preventDefault();
				window.location.assign(href);
			};

			document.addEventListener("keydown", onBlogShortcut);
		})();
	</script>
</SiteLayout>
