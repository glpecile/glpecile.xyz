---
import { siteConfig } from "#config/site";

import PageIntro from "@/components/page-intro.astro";
import SiteLayout from "@/layouts/site-layout.astro";
import { formatDate, getBlogPostUrl, getBlogPosts } from "@/lib/blog";

const posts = await getBlogPosts();
const latestPostCount = siteConfig.shortcuts.blog.latestPostCount;
const latestPostRange = `1-${latestPostCount}`;
const recentPostUrls = posts
	.slice(0, latestPostCount)
	.map((post) => getBlogPostUrl(post.id));
const introExtra = `use <span class="text-tone-mid">[${latestPostRange}]</span> for the latest posts · <span class="text-tone-mid">[j]/[k]</span> to move · <span class="text-tone-mid">[enter]</span> to open.<span class="mt-2 block">or subscribe via the <a class="terminal-link" href="/blog/rss.xml">rss feed</a>.</span>`;
---

<SiteLayout
	title="Blog"
	description="Thoughts, experiments, and project writeups."
	path="/blog"
	previewPath="/blog/preview"
>
	<section class="space-y-4">
		<PageIntro
			label="blog"
			title="Notes, builds, and rabbit holes."
			description="From tiny thoughts to full project writeups. Every post is just an mdx file — the latest nine get a keyboard shortcut."
			extra={posts.length > 0 ? introExtra : undefined}
			prompt="ls *.mdx"
			cwd="~/blog"
		/>

		{posts.length === 0 ? (
			<p class="text-tone-soft text-sm" data-reveal>no posts yet.</p>
		) : (
			<ol class="space-y-5" data-reveal>
				{posts.map((post, index) => (
					<li data-tui-row class="group space-y-1">
						<p class="text-tone-faint text-xs tracking-[0.28em] uppercase">
							{formatDate(post.data.updatedDate ?? post.data.pubDate)}
						</p>
						<p class="text-base leading-8 sm:text-lg">
							<a
								class="terminal-link group-hover:underline"
								href={getBlogPostUrl(post.id)}
							>
								{post.data.title}
							</a>
							{index < latestPostCount && (
								<span class="text-tone-faint"> [{index + 1}]</span>
							)}
						</p>
						<p class="text-tone-mid max-w-3xl text-sm leading-8 sm:text-base">
							{post.data.description}
						</p>
					</li>
				))}
			</ol>
		)}

	</section>

	<script
		is:inline
		define:vars={{ recentPostUrls }}
	>
		(() => {
			const editableTags = new Set(["INPUT", "TEXTAREA", "SELECT"]);

			const onBlogShortcut = (event) => {
				if (
					event.defaultPrevented ||
					event.repeat ||
					event.metaKey ||
					event.ctrlKey ||
					event.altKey
				) {
					return;
				}

				const target = event.target;

				if (
					target instanceof HTMLElement &&
					(editableTags.has(target.tagName) || target.isContentEditable)
				) {
					return;
				}

				if (!/^\d$/.test(event.key)) {
					return;
				}

				const index = Number(event.key) - 1;
				const href = recentPostUrls[index];

				if (!href) {
					return;
				}

				event.preventDefault();
				window.location.assign(href);
			};

			document.addEventListener("keydown", onBlogShortcut);
		})();
	</script>
</SiteLayout>
