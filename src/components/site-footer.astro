---
import { siteConfig } from "#config/site";

export interface Props {
	currentPath: string;
}

const { currentPath } = Astro.props;
const themeItems = siteConfig.shortcuts.theme;

// Render the current path like a shell cwd: `~` at home, `~/blog` elsewhere.
const termPath =
	currentPath === "/" ? "~" : `~${currentPath.replace(/\/+$/, "")}`;
---

<footer class="text-tone-soft bg-background sticky bottom-0 z-10 -mx-6 mt-12 text-sm sm:-mx-8">
	<div class="border-border mx-6 border-t sm:mx-8">
		<p class="flex flex-wrap items-center justify-between gap-x-6 gap-y-2 py-2">
		<span class="inline-flex items-center gap-4">
			<span class="text-tone-faint">{termPath}</span>
			<a
				class="terminal-link text-tone-mid"
				href={`${siteConfig.links.github}/glpecile.xyz`}
				target="_blank"
				rel="noopener noreferrer"
			>
				source code
			</a>
		</span>
		<span
			class="inline-flex flex-wrap items-center gap-x-2 gap-y-2 text-sm sm:flex-nowrap sm:gap-2"
			data-theme-picker
		>
			<span class="text-tone-faint text-[0.72rem] tracking-[0.28em] uppercase">theme</span>
			{themeItems.map((item) => (
				<button
					type="button"
					data-theme-option={item.theme}
					data-theme-shortcut={item.shortcut}
					aria-keyshortcuts={item.shortcut}
					aria-label={`${item.theme} theme`}
					class="text-tone-soft group inline-flex cursor-pointer items-center gap-1.5 px-1 focus-visible:outline-none"
				>
					<span
						data-theme-label
						class="group-hover:underline group-focus-visible:underline"
					>[{item.shortcut}]</span>
					<span
						aria-hidden="true"
						class:list={[
							"inline-block h-[0.7em] w-[0.7em] rounded-full border border-current",
							item.theme === "auto" &&
								"bg-[linear-gradient(90deg,currentColor_50%,transparent_50%)]",
							item.theme === "dark" && "bg-current",
						]}
					></span>
				</button>
			))}
		</span>
		</p>
	</div>
</footer>

<script is:inline>
	(() => {
		const currentScript = document.currentScript;
		const footer =
			currentScript instanceof HTMLScriptElement ? currentScript.previousElementSibling : null;

		if (footer instanceof HTMLElement) {
			const themePicker = footer.querySelector("[data-theme-picker]");
			const themeButtons = Array.from(footer.querySelectorAll("[data-theme-option]"));
			const themeEditableTags = new Set(["INPUT", "TEXTAREA", "SELECT"]);
			const themeMap = new Map(
				themeButtons.flatMap((button) =>
					button instanceof HTMLButtonElement &&
					typeof button.dataset.themeOption === "string" &&
					typeof button.dataset.themeShortcut === "string"
						? [[button.dataset.themeShortcut.toLowerCase(), button.dataset.themeOption]]
						: [],
				),
			);

			const setThemeButtonState = (theme) => {
				themeButtons.forEach((button) => {
					if (!(button instanceof HTMLButtonElement)) {
						return;
					}

					const isActive = button.dataset.themeOption === theme;
					const label = button.querySelector("[data-theme-label]");

					button.dataset.active = isActive ? "true" : "false";
					button.setAttribute("aria-pressed", isActive ? "true" : "false");
					button.classList.toggle("text-foreground", isActive);
					button.classList.toggle("text-tone-soft", !isActive);

					if (label instanceof HTMLElement) {
						label.classList.toggle("underline", isActive);
					}
				});
			};

			const syncThemeButtons = (theme) => {
				window.__glpecileTheme.apply(theme);
				setThemeButtonState(theme);
			};

			const storedTheme =
				window.__glpecileTheme.root.dataset.themePreference === "light" ||
				window.__glpecileTheme.root.dataset.themePreference === "dark"
					? window.__glpecileTheme.root.dataset.themePreference
					: "auto";

			syncThemeButtons(storedTheme);

			window.__glpecileTheme.media.addEventListener("change", () => {
				if (window.__glpecileTheme.root.dataset.themePreference === "auto") {
					syncThemeButtons("auto");
				}
			});

			if (themePicker instanceof HTMLElement) {
				themePicker.addEventListener("click", (event) => {
					const target = event.target;
					const button =
						target instanceof Element ? target.closest("[data-theme-option]") : null;

					if (!(button instanceof HTMLButtonElement)) {
						return;
					}

					const theme = button.dataset.themeOption;

					if (!theme) {
						return;
					}

					window.__glpecileTheme.persist(theme);
					syncThemeButtons(theme);
				});
			}

			document.addEventListener("keydown", (event) => {
				if (
					event.defaultPrevented ||
					event.repeat ||
					event.metaKey ||
					event.ctrlKey ||
					event.altKey
				) {
					return;
				}

				const target = event.target;

				if (
					target instanceof HTMLElement &&
					(themeEditableTags.has(target.tagName) || target.isContentEditable)
				) {
					return;
				}

				const theme = themeMap.get(event.key.toLowerCase());

				if (!theme) {
					return;
				}

				event.preventDefault();
				window.__glpecileTheme.persist(theme);
				syncThemeButtons(theme);
			});
		}
	})();
</script>
