---
interface Props {
	code: string;
	caption?: string;
}

const { code, caption } = Astro.props;
---

<figure class="mermaid-diagram" data-mermaid-source={code}>
	<pre class="mermaid-diagram-fallback">{code}</pre>
	{caption && <figcaption>{caption}</figcaption>}
</figure>

<script>
	import mermaid from "mermaid";

	const diagrams = Array.from(
		document.querySelectorAll<HTMLElement>(".mermaid-diagram"),
	);
	let renderSeq = 0;

	const renderAll = async () => {
		const isDark = document.documentElement.dataset.theme === "dark";
		mermaid.initialize({
			startOnLoad: false,
			theme: isDark ? "dark" : "neutral",
			fontFamily: "'JetBrains Mono', monospace",
			suppressErrorRendering: true,
		});
		for (const figure of diagrams) {
			const source = figure.dataset.mermaidSource;
			if (!source) continue;
			const renderId = `mermaid-${renderSeq++}`;
			try {
				const { svg } = await mermaid.render(renderId, source);
				const caption = figure.querySelector("figcaption");
				figure.innerHTML = svg;
				if (caption) figure.appendChild(caption);
				const svgEl = figure.querySelector("svg");
				if (svgEl) {
					// Mermaid emits role="graphics-document document", which
					// assistive tech and audits don't recognize.
					svgEl.setAttribute("role", "img");
					svgEl.removeAttribute("aria-roledescription");
					svgEl.setAttribute(
						"aria-label",
						caption?.textContent?.trim() || "Diagram",
					);
				}
			} catch {
				// Leave the source-text fallback in place, and drop the
				// scratch element mermaid appends to <body> on failure.
				document.getElementById(renderId)?.remove();
			}
		}
	};

	if (diagrams.length > 0) {
		renderAll();
		new MutationObserver(renderAll).observe(document.documentElement, {
			attributeFilter: ["data-theme"],
		});
	}
</script>

<style>
	.mermaid-diagram {
		margin: 2rem 0;
		overflow-x: auto;
	}

	.mermaid-diagram :global(svg) {
		margin-inline: auto;
		max-width: 100%;
		height: auto;
	}

	.mermaid-diagram-fallback {
		font-size: 0.8rem;
		overflow-x: auto;
	}

	.mermaid-diagram figcaption {
		margin-top: 0.75rem;
		text-align: center;
		font-size: 0.85rem;
		opacity: 0.7;
	}
</style>
