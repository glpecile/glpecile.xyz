---
import { siteConfig } from "#config/site";

import SectionLabel from "@/components/section-label.astro";
import SiteLayout from "@/layouts/site-layout.astro";

export interface Props {
	code: string;
	title: string;
	description: string;
	hint?: string;
	error?: unknown;
	path?: string;
}

const { code, title, description, hint, error, path = "/" } = Astro.props;
const navItems = siteConfig.shortcuts.nav.map((item) => ({
	...item,
	label: item.title.toLowerCase(),
}));

const details =
	error instanceof Error
		? error.message
		: typeof error === "string"
			? error
			: undefined;
---

<SiteLayout title={`${code} | ${title}`} description={description} path={path}>
	<section class="space-y-6">
		<SectionLabel label="error" />
		<div class="space-y-3">
			<p class="text-tone-faint text-sm tracking-[0.32em] uppercase">{code}</p>
			<h1 class="page-heading max-w-3xl text-3xl font-bold tracking-tight sm:text-5xl">
				{title}
			</h1>
			<p class="text-tone-mid max-w-3xl text-sm leading-8 sm:text-base">
				{description}
			</p>
			{hint && (
				<p class="text-tone-soft max-w-3xl text-sm leading-8 sm:text-base">
					{hint}
				</p>
			)}
		</div>

		<div class="flex flex-wrap items-center gap-x-5 gap-y-3 text-sm sm:text-base">
			{navItems.map((item) => (
				<a
					href={item.href}
					class="terminal-link inline-flex items-center gap-2"
					aria-keyshortcuts={item.shortcut}
				>
					<span class="text-tone-faint">[{item.shortcut}]</span>
					<span>{item.label}</span>
				</a>
			))}
		</div>

		{details && (
			<pre class="text-tone-soft border-foreground/18 overflow-x-auto border-l pl-4 text-sm leading-7">{details}</pre>
		)}
	</section>
</SiteLayout>
