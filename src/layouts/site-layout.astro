---
import { Image } from "astro:assets";
import { siteConfig } from "#config/site";

import "@/styles/global.css";

type MetaType = "article" | "website";

export interface Props {
	title?: string;
	description?: string;
	path?: string;
	previewPath?: string;
	type?: MetaType;
	publishedTime?: string;
}

const {
	title = siteConfig.shortName,
	description = siteConfig.description,
	path = "/",
	previewPath = "/preview",
	type = "website",
	publishedTime,
} = Astro.props;

const currentPath = Astro.url.pathname;
const pageTitle =
	title === siteConfig.shortName
		? siteConfig.shortName
		: `${title} | ${siteConfig.shortName}`;
const canonicalUrl = new URL(path, siteConfig.siteUrl).toString();
const ogImageBase = import.meta.env.DEV ? Astro.url.origin : siteConfig.siteUrl;
const ogImageUrl = new URL(previewPath, ogImageBase).toString();
const shortcuts = siteConfig.mainNav.map(({ href, shortcut }) => ({
	href,
	shortcut,
}));
const isCurrentPath = (href: string) =>
	href === "/"
		? currentPath === "/"
		: currentPath === href || currentPath.startsWith(`${href}/`);
const navItems = siteConfig.mainNav.map((item) => ({
	...item,
	isActive: isCurrentPath(item.href),
}));
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta name="author" content={siteConfig.author} />
		<meta name="description" content={description} />
		<meta name="robots" content="index,follow" />
		<meta name="category" content={siteConfig.category} />
		<meta name="theme-color" content={siteConfig.themeColor} />
		<meta property="og:locale" content="en_US" />
		<meta property="og:site_name" content={siteConfig.shortName} />
		<meta property="og:type" content={type} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:type" content="image/png" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={`${siteConfig.shortName} og image`} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<meta name="twitter:image:alt" content={`${siteConfig.shortName} og image`} />
		{type === "article" && publishedTime && (
			<meta property="article:published_time" content={publishedTime} />
		)}
		<link rel="canonical" href={canonicalUrl} />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="apple-touch-icon" href="/apple-icon.png" />
		<link rel="manifest" href="/manifest.webmanifest" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
		<link
			href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700;800&display=swap"
			rel="stylesheet"
		/>
		<script is:inline>
			window.__glpecileTheme = {
				storageKey: "glpecile-theme",
				root: document.documentElement,
				media: window.matchMedia("(prefers-color-scheme: dark)"),
				getSystemTheme() {
					return this.media.matches ? "dark" : "light";
				},
				apply(theme) {
					const resolvedTheme = theme === "auto" ? this.getSystemTheme() : theme;

					this.root.dataset.theme = resolvedTheme;
					this.root.dataset.themePreference = theme;
				},
				persist(theme) {
					try {
						if (theme === "auto") {
							localStorage.removeItem(this.storageKey);
						} else {
							localStorage.setItem(this.storageKey, theme);
						}
					} catch {
						// Ignore browsers that block storage access.
					}
				},
			};

			try {
				const storedTheme = localStorage.getItem(window.__glpecileTheme.storageKey);
				window.__glpecileTheme.apply(
					storedTheme === "light" || storedTheme === "dark" ? storedTheme : "auto",
				);
			} catch {
				window.__glpecileTheme.apply("auto");
			}

			window.__glpecileTheme.media.addEventListener("change", () => {
				if (window.__glpecileTheme.root.dataset.themePreference === "auto") {
					window.__glpecileTheme.apply("auto");
				}
			});
		</script>
		<script is:inline>
			try {
				if (sessionStorage.getItem("glpecile-shortcut-nav") === "true") {
					document.documentElement.dataset.shortcutNav = "true";
					sessionStorage.removeItem("glpecile-shortcut-nav");
				}
			} catch {
				// Ignore browsers that block storage access.
			}
		</script>
	</head>
	<body class="min-h-screen bg-background text-foreground antialiased">
		<div class="mx-auto flex min-h-screen w-full max-w-4xl flex-col px-6 py-8 sm:px-8 md:py-12">
			<main class="flex flex-1 flex-col gap-12">
			<header class="flex items-start justify-between gap-5">
				<a
					href="/"
					class="inline-flex w-fit items-center gap-3 no-underline"
				>
					<Image
						src="/images/me.png"
						alt="Portrait of Gian Luca Pecile"
						width={28}
						height={28}
						loading="eager"
						class="rounded-full"
					/>
					<span>
						<span
							class="block text-xl font-bold tracking-tight sm:text-2xl"
							data-scramble
							data-text={siteConfig.shortName}
						>
							{siteConfig.shortName}
						</span>
					</span>
				</a>

				<details class="relative sm:hidden" data-mobile-nav>
					<summary
						aria-label="Toggle navigation"
						class="text-tone-mid inline-flex h-10 w-10 cursor-pointer list-none items-center justify-center transition-colors hover:text-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-foreground/30 [&::-webkit-details-marker]:hidden"
					>
						<span aria-hidden="true" class="flex flex-col gap-1.5">
							<span class="block h-px w-5 bg-current"></span>
							<span class="block h-px w-5 bg-current"></span>
							<span class="block h-px w-5 bg-current"></span>
						</span>
					</summary>

					<nav
						aria-label="Mobile primary"
						class="absolute right-0 top-full z-10 mt-3 min-w-44 border border-foreground/10 bg-background px-4 py-3"
					>
						<ul class="flex flex-col gap-3 text-left text-sm">
							{navItems.map((item) => (
								<li>
									<a
										href={item.href}
										aria-current={item.isActive ? "page" : undefined}
										aria-keyshortcuts={item.shortcut}
										class:list={[
											"terminal-link inline-flex w-full items-center justify-between gap-4",
											item.isActive ? "text-foreground" : "text-tone-mid",
										]}
									>
										<span class="text-tone-faint">[{item.shortcut}]</span>
										<span class:list={["lowercase", item.isActive && "underline"]}>
											{item.title}
										</span>
									</a>
								</li>
							))}
						</ul>
					</nav>
				</details>

				<nav aria-label="Primary" class="hidden sm:block sm:w-auto">
					<ul class="flex items-center gap-x-5 gap-y-2 text-sm sm:justify-start">
						{navItems.map((item) => (
							<li>
								<a
									href={item.href}
									aria-current={item.isActive ? "page" : undefined}
									aria-keyshortcuts={item.shortcut}
									class:list={[
										"terminal-link inline-flex items-center gap-2",
										item.isActive ? "text-foreground" : "text-tone-mid",
									]}
								>
									<span class="text-tone-faint">[{item.shortcut}]</span>
									<span class:list={["lowercase", item.isActive && "underline"]}>
										{item.title}
									</span>
								</a>
							</li>
						))}
					</ul>
				</nav>
			</header>

			<slot />
			</main>

			<footer class="text-tone-soft pt-12 text-sm">
				<p class="flex flex-wrap items-center justify-between gap-x-6 gap-y-3">
					<span class="inline-flex items-center gap-2">
						<svg
							viewBox="0 0 16 16"
							aria-hidden="true"
							class="text-tone-mid h-4 w-4 fill-current"
						>
							<path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.65 7.65 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"></path>
						</svg>
						<a
							class="terminal-link text-tone-mid"
							href="https://github.com/glpecile/glpecile.xyz"
							target="_blank"
							rel="noopener noreferrer"
						>
							source code
						</a>
					</span>
					<span
						class="inline-flex flex-wrap items-center gap-x-2 gap-y-2 text-sm sm:flex-nowrap sm:gap-2"
						data-theme-picker
					>
						<span class="text-tone-faint text-[0.72rem] uppercase tracking-[0.28em]">
							theme
						</span>
						<button
							type="button"
							data-theme-option="auto"
							aria-keyshortcuts="a"
							class="terminal-link text-tone-soft cursor-pointer px-1"
						>
							[a]
						</button>
						<button
							type="button"
							data-theme-option="light"
							aria-keyshortcuts="l"
							class="terminal-link text-tone-soft cursor-pointer px-1"
						>
							[l]
						</button>
						<button
							type="button"
							data-theme-option="dark"
							aria-keyshortcuts="d"
							class="terminal-link text-tone-soft cursor-pointer px-1"
						>
							[d]
						</button>
					</span>
				</p>
			</footer>
		</div>

		<script is:inline data-shortcuts={JSON.stringify(shortcuts)}>
			const currentScript = document.currentScript;
			const shortcuts = JSON.parse(
				currentScript instanceof HTMLScriptElement
					? currentScript.dataset.shortcuts ?? "[]"
					: "[]",
			);
			const editableTags = new Set(["INPUT", "TEXTAREA", "SELECT"]);

			const onShortcut = (event) => {
				if (
					event.defaultPrevented ||
					event.repeat ||
					event.metaKey ||
					event.ctrlKey ||
					event.altKey
				) {
					return;
				}

				const target = event.target;

				if (
					target instanceof HTMLElement &&
					(editableTags.has(target.tagName) || target.isContentEditable)
				) {
					return;
				}

				const shortcut = shortcuts.find(
					(item) => item.shortcut.toLowerCase() === event.key.toLowerCase(),
				);

				if (!shortcut) {
					return;
				}

				event.preventDefault();

				if (window.location.pathname === shortcut.href) {
					window.scrollTo({ top: 0 });
					return;
				}

				try {
					sessionStorage.setItem("glpecile-shortcut-nav", "true");
				} catch {
					// Ignore browsers that block storage access.
				}

				window.location.assign(shortcut.href);
			};

			document.addEventListener("keydown", onShortcut);
		</script>

		<script is:inline>
			const themePicker = document.querySelector("[data-theme-picker]");
			const themeButtons = Array.from(
				document.querySelectorAll("[data-theme-option]"),
			);
			const themeEditableTags = new Set(["INPUT", "TEXTAREA", "SELECT"]);

			const setThemeButtonState = (theme) => {
				themeButtons.forEach((button) => {
					if (!(button instanceof HTMLButtonElement)) {
						return;
					}

					const isActive = button.dataset.themeOption === theme;

					button.dataset.active = isActive ? "true" : "false";
					button.setAttribute("aria-pressed", isActive ? "true" : "false");
					button.classList.toggle("text-foreground", isActive);
					button.classList.toggle("underline", isActive);
					button.classList.toggle("text-tone-soft", !isActive);
				});
			};

			const syncThemeButtons = (theme) => {
				window.__glpecileTheme.apply(theme);
				setThemeButtonState(theme);
			};

			const storedTheme =
				window.__glpecileTheme.root.dataset.themePreference === "light" ||
				window.__glpecileTheme.root.dataset.themePreference === "dark"
					? window.__glpecileTheme.root.dataset.themePreference
					: "auto";

			syncThemeButtons(storedTheme);

			window.__glpecileTheme.media.addEventListener("change", () => {
				if (window.__glpecileTheme.root.dataset.themePreference === "auto") {
					syncThemeButtons("auto");
				}
			});

			if (themePicker instanceof HTMLElement) {
				themePicker.addEventListener("click", (event) => {
					const target = event.target;

					if (!(target instanceof HTMLButtonElement)) {
						return;
					}

					const theme = target.dataset.themeOption;

					if (theme !== "auto" && theme !== "light" && theme !== "dark") {
						return;
					}

					window.__glpecileTheme.persist(theme);
					syncThemeButtons(theme);
				});
			}

			document.addEventListener("keydown", (event) => {
				if (
					event.defaultPrevented ||
					event.repeat ||
					event.metaKey ||
					event.ctrlKey ||
					event.altKey
				) {
					return;
				}

				const target = event.target;

				if (
					target instanceof HTMLElement &&
					(themeEditableTags.has(target.tagName) || target.isContentEditable)
				) {
					return;
				}

				const themeMap = {
					a: "auto",
					l: "light",
					d: "dark",
				};
				const theme = themeMap[event.key.toLowerCase()];

				if (!theme) {
					return;
				}

				event.preventDefault();
				window.__glpecileTheme.persist(theme);
				syncThemeButtons(theme);
			});
		</script>

		<script is:inline>
			const mobileNav = document.querySelector("[data-mobile-nav]");

			if (mobileNav instanceof HTMLDetailsElement) {
				const closeMobileNav = () => {
					mobileNav.open = false;
				};

				document.addEventListener("click", (event) => {
					if (!mobileNav.open) {
						return;
					}

					const target = event.target;

					if (target instanceof Node && !mobileNav.contains(target)) {
						closeMobileNav();
					}
				});

				document.addEventListener("keydown", (event) => {
					if (event.key === "Escape") {
						closeMobileNav();
					}
				});

				mobileNav.querySelectorAll("a").forEach((link) => {
					link.addEventListener("click", closeMobileNav);
				});
			}
		</script>

		<script is:inline>
			const element = document.querySelector("[data-scramble]");
			const text = element?.getAttribute("data-text") ?? "";
			const prefersReducedMotion = window.matchMedia(
				"(prefers-reduced-motion: reduce)",
			).matches;
			const skipScramble =
				prefersReducedMotion ||
				document.documentElement.dataset.shortcutNav === "true";

			if (element instanceof HTMLElement && text) {
				if (skipScramble) {
					element.textContent = text;
				} else {
					const characters =
						"ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789";
					const scrambleFrames = 5;
					let frame = 0;

					const interval = window.setInterval(() => {
						const settled = Math.max(0, frame - scrambleFrames);

						element.textContent = text
							.split("")
							.map((character, index) => {
								if (index < settled) {
									return character;
								}

								return characters[Math.floor(Math.random() * characters.length)];
							})
							.join("");

						frame += 1;

						if (settled >= text.length) {
							window.clearInterval(interval);
							element.textContent = text;
						}
					}, 16);
				}
			}
		</script>
	</body>
</html>
