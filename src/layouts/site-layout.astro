---
import meAvatar from "@/assets/me-avatar.webp?inline";
import SiteFooter from "@/components/site-footer.astro";
import SiteNav from "@/components/site-nav.astro";
import { getMarkdownPath } from "@/lib/llms";
import { siteConfig } from "#config/site";

import "@/styles/global.css";

type MetaType = "article" | "website";

export interface Props {
	title?: string;
	description?: string;
	path?: string;
	previewPath?: string;
	type?: MetaType;
	publishedTime?: string;
}

const {
	title = siteConfig.shortName,
	description = siteConfig.description,
	path = "/",
	previewPath = "/preview",
	type = "website",
	publishedTime,
} = Astro.props;

const currentPath = Astro.url.pathname;
const pageTitle =
	title === siteConfig.shortName
		? siteConfig.shortName
		: `${title} | ${siteConfig.shortName}`;
const canonicalUrl = new URL(path, siteConfig.siteUrl).toString();
const markdownUrl = new URL(getMarkdownPath(path), siteConfig.siteUrl).toString();
const llmsUrl = new URL("/llms.txt", siteConfig.siteUrl).toString();
const ogImageBase = import.meta.env.DEV ? Astro.url.origin : siteConfig.siteUrl;
const ogImageUrl = new URL(previewPath, ogImageBase).toString();
const shortcuts = siteConfig.shortcuts.nav.map(({ href, shortcut }) => ({
	href,
	shortcut,
}));
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta name="author" content={siteConfig.author} />
		<meta name="description" content={description} />
		<meta name="robots" content="index,follow" />
		<meta name="category" content={siteConfig.category} />
		<meta name="theme-color" content={siteConfig.themeColor} />
		<meta property="og:locale" content="en_US" />
		<meta property="og:site_name" content={siteConfig.shortName} />
		<meta property="og:type" content={type} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:type" content="image/png" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={`${siteConfig.shortName} og image`} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<meta name="twitter:image:alt" content={`${siteConfig.shortName} og image`} />
		{type === "article" && publishedTime && (
			<meta property="article:published_time" content={publishedTime} />
		)}
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" type="text/markdown" href={markdownUrl} />
		<link rel="alternate" type="text/plain" href={llmsUrl} />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="apple-touch-icon" href="/apple-icon.png" />
		<link rel="manifest" href="/manifest.webmanifest" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
		<link
			href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700;800&display=swap"
			rel="stylesheet"
		/>
		<script is:inline>
			(() => {
				const createThemeController = () => ({
					storageKey: "glpecile-theme",
					root: document.documentElement,
					media: window.matchMedia("(prefers-color-scheme: dark)"),
					getSystemTheme() {
						return this.media.matches ? "dark" : "light";
					},
					apply(theme) {
						this.root.dataset.theme = theme === "auto" ? this.getSystemTheme() : theme;
						this.root.dataset.themePreference = theme;
					},
					persist(theme) {
						try {
							if (theme === "auto") {
								localStorage.removeItem(this.storageKey);
							} else {
								localStorage.setItem(this.storageKey, theme);
							}
						} catch {
							// Ignore browsers that block storage access.
						}
					},
				});

				window.__glpecileTheme = createThemeController();

				try {
					const storedTheme = localStorage.getItem(window.__glpecileTheme.storageKey);
					window.__glpecileTheme.apply(
						storedTheme === "light" || storedTheme === "dark" ? storedTheme : "auto",
					);
				} catch {
					window.__glpecileTheme.apply("auto");
				}

				window.__glpecileTheme.media.addEventListener("change", () => {
					if (window.__glpecileTheme.root.dataset.themePreference === "auto") {
						window.__glpecileTheme.apply("auto");
					}
				});
			})();
		</script>
		<script is:inline>
			(() => {
				try {
					if (sessionStorage.getItem("glpecile-shortcut-nav") === "true") {
						document.documentElement.dataset.shortcutNav = "true";
						sessionStorage.removeItem("glpecile-shortcut-nav");
					}
				} catch {
					// Ignore browsers that block storage access.
				}
			})();
		</script>
		<script is:inline>
			(() => {
				const root = document.documentElement;
				const prefersReducedMotion = window.matchMedia(
					"(prefers-reduced-motion: reduce)",
				).matches;
				const skipReveal =
					prefersReducedMotion || root.dataset.shortcutNav === "true";

				// Hide reveal targets before they paint. Skipping this leaves
				// them fully visible for no-JS, reduced-motion, and shortcut nav.
				if (!skipReveal) {
					root.dataset.revealReady = "";
				}
			})();
		</script>
	</head>
	<body class="bg-background text-foreground min-h-screen antialiased">
		<div class="mx-auto flex min-h-screen w-full max-w-4xl flex-col px-6 py-8 sm:px-8 md:py-12">
			<main class="flex flex-1 flex-col gap-12">
			<header class="flex items-center justify-between gap-5 sm:items-start">
				<a
					href="/"
					class="inline-flex w-fit items-center gap-3 no-underline"
				>
					<img
						src={meAvatar}
						alt="Portrait of Gian Luca Pecile"
						width={28}
						height={28}
						loading="eager"
						decoding="sync"
						fetchpriority="high"
						class="h-7 w-7 shrink-0 rounded-full"
					/>
					<span>
						<span
							class="block text-xl font-bold tracking-tight sm:text-2xl"
							data-scramble
							data-text={siteConfig.shortName}
						>
							{siteConfig.shortName}
						</span>
					</span>
				</a>

				<SiteNav currentPath={currentPath} />
			</header>

			<slot />
			</main>

			<SiteFooter />
		</div>

		<script is:inline data-shortcuts={JSON.stringify(shortcuts)}>
			(() => {
				const currentScript = document.currentScript;
				const shortcuts = JSON.parse(
					currentScript instanceof HTMLScriptElement
						? currentScript.dataset.shortcuts ?? "[]"
						: "[]",
				);
				const editableTags = new Set(["INPUT", "TEXTAREA", "SELECT"]);

				const onShortcut = (event) => {
					if (
						event.defaultPrevented ||
						event.repeat ||
						event.metaKey ||
						event.ctrlKey ||
						event.altKey
					) {
						return;
					}

					const target = event.target;

					if (
						target instanceof HTMLElement &&
						(editableTags.has(target.tagName) || target.isContentEditable)
					) {
						return;
					}

					const shortcut = shortcuts.find(
						(item) => item.shortcut.toLowerCase() === event.key.toLowerCase(),
					);

					if (!shortcut) {
						return;
					}

					event.preventDefault();

					if (window.location.pathname === shortcut.href) {
						window.scrollTo({ top: 0 });
						return;
					}

					try {
						sessionStorage.setItem("glpecile-shortcut-nav", "true");
					} catch {
						// Ignore browsers that block storage access.
					}

					window.location.assign(shortcut.href);
				};

				document.addEventListener("keydown", onShortcut);
			})();
		</script>

		<script is:inline>
			(() => {
				const element = document.querySelector("[data-scramble]");
				const text = element?.getAttribute("data-text") ?? "";
				const prefersReducedMotion = window.matchMedia(
					"(prefers-reduced-motion: reduce)",
				).matches;
				const skipScramble =
					prefersReducedMotion ||
					document.documentElement.dataset.shortcutNav === "true";

				if (element instanceof HTMLElement && text) {
					if (skipScramble) {
						element.textContent = text;
					} else {
						const characters =
							"ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789";
						const scrambleFrames = 5;
						let frame = 0;

						const interval = window.setInterval(() => {
							const settled = Math.max(0, frame - scrambleFrames);

							element.textContent = text
								.split("")
								.map((character, index) => {
									if (index < settled) {
										return character;
									}

									return characters[Math.floor(Math.random() * characters.length)];
								})
								.join("");

							frame += 1;

							if (settled >= text.length) {
								window.clearInterval(interval);
								element.textContent = text;
							}
						}, 16);
					}
				}
			})();
		</script>

		<script is:inline>
			(() => {
				const root = document.documentElement;

				// Only run when the head decided the cascade should play.
				if (root.dataset.revealReady !== "") {
					return;
				}

				// Number the targets in DOM order so the cascade flows
				// top-to-bottom across intro lines and the sections below.
				document.querySelectorAll("[data-reveal]").forEach((element, index) => {
					element.style.setProperty("--reveal-index", String(index));
				});

				// Indices are set — release the animation.
				root.dataset.revealGo = "";
			})();
		</script>
	</body>
</html>
