{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor",
    "schedule:weekly",
    ":approveMajorUpdates",
    ":automergeMinor",
    "schedule:weekly",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)"
  ],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "description": "The astro + vite + cloudflare dev toolchain is tightly coupled: version skew between astro, vite, and the workerd runtime has broken `astro dev` before (vite 8.1.3+ with astro <=7.0.8). Never automerge these; each update must be approved from the dependency dashboard and verified with `bun dev` + `bun run build` locally.",
      "matchPackageNames": [
        "astro",
        "vite",
        "wrangler",
        "miniflare",
        "workerd",
        "@astrojs/**",
        "@cloudflare/**"
      ],
      "groupName": "astro/vite/cloudflare toolchain",
      "automerge": false,
      "dependencyDashboardApproval": true
    }
  ],
  "ignoreDeps": [
    "@types/react",
    "@types/react-dom",
    "react",
    "react-dom",
    "next",
    "eslint-config-next"
  ]
}
