{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"baseUrl": ".",
		"types": ["vite/client"],
		"paths": {
			"@/*": ["./src/*"],
			"#config/*": ["./config/*"]
		},
		"jsx": "react-jsx",
		"jsxImportSource": "react"
	},
	"include": [
		".astro/types.d.ts",
		"src/**/*",
		"config/**/*",
		"./wasm-modules.d.ts",
		"./worker-configuration.d.ts"
	]
}
